{
  "name": "local-router",
  "version": "1.0.0",
  "description": "A local Ollama-compatible and OpenAI-compatible model router for VS Code and localhost AI tooling.",
  "main": "index.js",
  "bin": {
    "local-router": "bin/local-router.js",
    "fvs-code": "bin/fvs-code.js"
  },
  "scripts": {
    "test": "npm run test:integration",
    "test:integration": "npm run build && node --test tests/provider-keys.integration.test.mjs",
    "start": "node build/index.js",
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "cli": "node bin/local-router.js"
  },
  "keywords": [
    "ollama",
    "ollama-proxy",
    "local-llm-router",
    "openai-compatible",
    "vs-code",
    "model-router"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
